# UUON Foundation - Railway Production Environment Variables
# Copy these into Railway dashboard: https://railway.app/dashboard

# Database
DATABASE_URL=postgresql://user:password@host:5432/uuon_production
DB_HOST=your-railway-postgres-host
DB_PORT=5432
DB_NAME=uuon_production
DB_USER=postgres
DB_PASSWORD=your_secure_password

# API Configuration
NODE_ENV=production
PORT=8080
API_BASE_URL=https://your-railway-app.railway.app
API_PORT=8080

# Replit OAuth
REPLIT_CLIENT_ID=your_replit_client_id
REPLIT_CLIENT_SECRET=your_replit_client_secret
REPLIT_REDIRECT_URI=https://your-railway-app.railway.app/auth/replit/callback

# Blockchain (PIEZ)
BLOCKCHAIN_RPC_URL=https://mainnet.infura.io/v3/your-infura-key
BLOCKCHAIN_CONTRACT_ADDRESS=0x...
BLOCKCHAIN_PRIVATE_KEY=your_private_key

# Billing
CREDIT_PRICE_USD=0.01
PLATFORM_FEE_PERCENT=25

# Logging
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn

# GitHub Actions (for CI/CD)
RAILWAY_TOKEN=your_railway_api_token
RAILWAY_PROJECT_ID=your_railway_project_id
